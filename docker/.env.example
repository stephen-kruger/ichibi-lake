# Docker Host User IDs for permission mapping
# Set these to the UID/GID of the user running Docker on the remote host
# You can get these by running 'id' command on the Docker host machine
DOCKER_HOST_UID=1000
DOCKER_HOST_GID=1000

# API Keys (comma-separated)
# Used as the default when RBAC env vars are not set.
API_KEYS=ICHIBI_LAKE_TEST_7a96c3e2-b1fe-4705-9064-fc1882674b13

# Kafka broker(s) for SSE subscription and internal consumer (comma-separated)
# When using the kafka service in compose.yaml, use the service name:
KAFKA_BROKERS=kafka:9092

# Kafka log retention (delete-policy topics). Tune to bound on-disk usage.
# Defaults shown match compose.yaml fallbacks.
# KAFKA_LOG_RETENTION_HOURS=168              # 7 days
# KAFKA_LOG_RETENTION_BYTES=1073741824       # 1 GiB per partition (-1 = unlimited)
# KAFKA_LOG_SEGMENT_BYTES=268435456          # 256 MiB; segments must roll before deletion
# KAFKA_LOG_RETENTION_CHECK_INTERVAL_MS=60000

# Read-only SQL enforcement for user-supplied SQL endpoints
# (POST /query, the /graphql sql resolver, and POST /graphs/:graphName/query).
# When true (default), DDL/DML keywords are rejected with HTTP 403.
# Set to false to allow arbitrary statements (ops/migration use only).
SQL_READ_ONLY=true

# =============================================================================
# RBAC (Role-Based Access Control)
# =============================================================================
# When RBAC_SUPERUSERS or RBAC_USERS is set, the gateway switches from the
# simple API_KEYS list to a full RBAC model with roles (superuser, writer,
# reader) and per-table permission overrides. Users are synced to the DuckLake
# metadata store (Postgres) on every startup so a fresh database is always
# populated from these environment variables.
#
# At least one superuser API key is required when RBAC is enabled.
#
# Examples:
#   RBAC_SUPERUSERS=sk-admin-abc123,sk-admin-def456
#
#   RBAC_USERS=[{"apiKey":"sk-admin-abc123","name":"Alice","roles":["superuser"]},{"apiKey":"sk-writer-789","name":"Bob","roles":["writer"]},{"apiKey":"sk-reader-012","name":"Carol","roles":["reader"]}]
#
#   RBAC_TABLE_PERMISSIONS=[{"apiKey":"sk-writer-789","tableName":"payroll","permission":"deny"}]
#
# =============================================================================
# RBAC_SUPERUSERS=
# RBAC_USERS=
# RBAC_TABLE_PERMISSIONS=

# Start the DuckDB UI service (browse the lake at http://localhost:4213).
# Enabled by default (1); set to 0 to skip starting it.
# WARNING: the UI grants full read/write access to the DuckLake data to anyone
# who can reach its port and performs no authentication. Do NOT expose it on a
# public/untrusted network — keep it bound to localhost or behind a VPN/auth proxy.
DUCKDB_UI_ENABLED=1
# Host port the DuckDB UI is published on (must match the in-UI port).
# DUCKDB_UI_PORT=4213